# =============================================================
# ERP System — Environment variables (PHASE 0 / cimientos)
# =============================================================
# Copy to .env and adjust. Never commit the real .env file.
# All secrets MUST come from environment in production.

# ---------- Postgres ----------
POSTGRES_USER=erp_admin
POSTGRES_PASSWORD=change_me_in_production_please
POSTGRES_DB=erp_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_TEST_DB=erp_db_test

# Backend reads these to build its DSN:
DATABASE_URL=postgresql+asyncpg://erp_admin:change_me_in_production_please@db:5432/erp_db
# Sync URL used by Alembic only (psycopg3 driver):
DATABASE_URL_SYNC=postgresql+psycopg://erp_admin:change_me_in_production_please@db:5432/erp_db

# ---------- Backend (FastAPI) ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_WORKERS=1
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO
APP_NAME=ERP System

# CORS — comma separated, NEVER use "*" with credentials in production
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# JWT — generate strong secrets, e.g. `openssl rand -hex 64`
JWT_SECRET_KEY=CHANGE_ME_USE_openssl_rand_hex_64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Argon2
ARGON2_TIME_COST=3
ARGON2_MEMORY_COST=65536
ARGON2_PARALLELISM=4

# Rate limiting (requests per minute per IP on sensitive endpoints)
LOGIN_RATE_LIMIT=10/minute
REFRESH_RATE_LIMIT=30/minute
RESET_RATE_LIMIT=5/minute

# Security headers
SECURE_COOKIES=true

# ---------- Frontend (SvelteKit) ----------
PUBLIC_API_URL=http://localhost:8000
PUBLIC_APP_NAME=ERP System
VITE_API_URL=http://localhost:8000

# ---------- Redis (optional, used from phase 1+) ----------
REDIS_URL=redis://redis:6379/0
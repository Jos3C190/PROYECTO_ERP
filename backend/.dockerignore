*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml
*.log
.env
.env.*
!.env.example
uploads/
.git/
.gitignore
Dockerfile
.dockerignore
uv.lock